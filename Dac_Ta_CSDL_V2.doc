<table border='1' cellspacing='0' cellpadding='5' style='border-collapse: collapse; width: 100%; margin-bottom: 20px;'>
<tr>
<th style='background-color: #f2f2f2; text-align: center; width: 50px;'><b>STT</b></th>
<th style='background-color: #f2f2f2; text-align: left;'><b>Thuộc tính</b></th>
<th style='background-color: #f2f2f2; text-align: left;'><b>Kiểu dữ liệu</b></th>
<th style='background-color: #f2f2f2; text-align: left;'><b>Ràng buộc</b></th>
<th style='background-color: #f2f2f2; text-align: left;'><b>Mô tả</b></th>
</tr>
<tr>
<td style='text-align: center;'>1</td>
<td>id</td>
<td>BIGINT</td>
<td>PK, Auto Inc</td>
<td>Khóa chính</td>
</tr>
<tr>
<td style='text-align: center;'>2</td>
<td>user_id</td>
<td>INT</td>
<td>FK</td>
<td>Tài khoản thực hiện hành động</td>
</tr>
<tr>
<td style='text-align: center;'>3</td>
<td>action</td>
<td>VARCHAR(255)</td>
<td>Not Null</td>
<td>Hành động (Ví dụ: Thay đổi giá hàng loạt)</td>
</tr>
<tr>
<td style='text-align: center;'>4</td>
<td>ip_address</td>
<td>VARCHAR(50)</td>
<td>Not Null</td>
<td>Địa chỉ IP</td>
</tr>
<tr>
<td style='text-align: center;'>5</td>
<td>timestamp</td>
<td>TIMESTAMP</td>
<td>Not Null</td>
<td>Lần thực hiện thao tác</td>
</tr>
</table>
</body></html>